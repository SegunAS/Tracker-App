<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed for step counter on Android 10+ (runtime permission too) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Needed to show notifications on Android 13+ (runtime permission too) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Optional: tells Play/device this app can use a step counter sensor (not required to install) -->
    <uses-feature
        android:name="android.hardware.sensor.stepcounter"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:label="Tracker App"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrackerApp">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Tracker App"
            android:theme="@style/Theme.TrackerApp">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>